{
  "name": "talimatlar",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "talimatlar-ai": "node scripts/run-talimatlar-ai.js",
    "talimatlar-watch": "node scripts/watch-talimatlar.js",
    "talimatlar-agent": "node scripts/run-talimatlar-agent.js",
    "talimatlar": "node scripts/run-talimatlar.js",
    "talimatlar-watch-daemon": "bash scripts/start-watch-daemon.sh",
    "talimatlar-watch-stop": "bash scripts/stop-watch-daemon.sh",
    "talimatlar-watch-status": "bash scripts/watch-status.sh",
    "start-system": "bash scripts/start-system.sh",
    "pm2-start": "pm2 start ecosystem.config.js",
    "pm2-stop": "pm2 delete ecosystem.config.js || pm2 delete talimatlar-watch || true",
    "pm2-status": "pm2 status",
    "pm2-logs": "pm2 logs",
    "talimatlar-ai-live": "LIVE_LOG=1 node scripts/run-talimatlar-ai.js",
    "talimatlar-watch-live": "LIVE_LOG=1 node scripts/watch-talimatlar.js",
    "talimatlar-logs": "tail -f logs/live.log 2>/dev/null || (mkdir -p logs && touch logs/live.log && tail -f logs/live.log)"
  },
  "dependencies": {
    "chokidar": "^3.5.3",
    "pm2": "^5.2.0"
  }
}